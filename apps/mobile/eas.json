{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "APP_ENV": "development" },
      "channel": "development",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": { "APP_ENV": "preview" },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "env": { "APP_ENV": "production" },
      "android": { "buildType": "app-bundle" }
    }
  }
}
