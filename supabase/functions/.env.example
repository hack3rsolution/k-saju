# Supabase Edge Functions — Server-side Secrets
# Set these via Supabase Dashboard → Project Settings → Edge Functions → Secrets
# Or via CLI: supabase secrets set KEY=value

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic / Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key — bypasses RLS for server-side DB access
# (Dashboard → Settings → API → service_role secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase project URL (same as EXPO_PUBLIC_SUPABASE_URL in the mobile app)
SUPABASE_URL=https://your-project.supabase.co

# ── Optional ──────────────────────────────────────────────────────────────────

# Supabase JWT secret — only needed if you verify JWTs manually in edge functions
# (Dashboard → Settings → API → JWT Secret)
# SUPABASE_JWT_SECRET=your-jwt-secret
