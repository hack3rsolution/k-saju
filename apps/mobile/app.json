{
  "expo": {
    "name": "K-Saju",
    "slug": "k-saju",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ksaju.global"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0a2e"
      },
      "package": "com.ksaju.global"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "ksaju",
    "experiments": {
      "typedRoutes": true
    }
  }
}
