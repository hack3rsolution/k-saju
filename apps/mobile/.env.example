# Supabase project settings (Settings → API in Supabase dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat API keys (RevenueCat dashboard → API Keys)
EXPO_PUBLIC_RC_API_KEY_IOS=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# EAS / GitHub Actions Secrets (set via: eas secret:create or GitHub repo settings)
# ─────────────────────────────────────────────────────────────────────────────

# Expo account token (https://expo.dev/accounts/[user]/settings/access-tokens)
# EXPO_TOKEN=your-expo-access-token

# iOS submission (App Store Connect)
# APPLE_ID=your@apple.id
# ASC_APP_ID=1234567890          # App Store Connect app ID (numeric)
# APPLE_TEAM_ID=XXXXXXXXXX       # Apple Developer Team ID

# Run `eas init` in apps/mobile to get your EAS project ID,
# then replace YOUR_EAS_PROJECT_ID in app.json with the actual value.
